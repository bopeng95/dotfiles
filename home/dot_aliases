# custom
alias editalias="cm edit --apply ~/.aliases"
alias editzprofile="cm edit --apply ~/.zprofile"
alias editzsh="cm edit --apply ~/.zshrc"
alias editss="cm edit --apply ~/.config/starship/starship.toml"
alias edittmux="cm edit --apply ~/.tmux.conf"
alias reset="source ~/.zshrc"

# claude
alias cc="claude --dangerously-skip-permissions"

# ssh
alias addssh="ssh-add --apple-use-keychain"

# webserver
alias webserver="ttyd -p 4200 -t fontSize=16 -W zsh"

# brew
alias bb="brew bundle"
alias bbd="bb dump --force --describe"
alias bbb="brew update && brew upgrade && brew cleanup"

# chezmoi
alias cm="chezmoi"

# eza
alias ls="eza --header --git --icons=always"
alias ll="eza -lg --header --git --icons=always"
alias la="eza -lag --header --git --icons=always"

# nvim
alias vim="nvim"

# zioxide
alias cd="z"

# tmux
alias tn="tmux new -s"
alias ta="tmux a -t"
alias tl="tmux ls"
alias tk="tmux kill-session -t"

